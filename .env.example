# ============================================
# WhatsApp Gateway — Environment Configuration
# ============================================
# Copy this file to .env and adjust values.
#   cp .env.example .env
#
# Docker Compose reads .env automatically when
# running from project root:
#   make docker-up
#   # or
#   docker compose --env-file .env -f deployments/docker-compose.yml up -d

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=9090
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=wachat
DB_PASSWORD=wachat_secret
DB_NAME=wa_gateway
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_MAX_LIFETIME=5m

# --- RabbitMQ ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=wachat
RABBITMQ_PASSWORD=wachat_secret
RABBITMQ_VHOST=/

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=wachat_secret
REDIS_DB=0

# --- WhatsApp API ---
# Get these from your Meta Business account:
#   https://developers.facebook.com/apps/
WHATSAPP_PHONE_NUMBER_ID=test_phone_id
WHATSAPP_WABA_ID=your_waba_id
WHATSAPP_ACCESS_TOKEN=test_token
WHATSAPP_API_VERSION=v20.0
WHATSAPP_VERIFY_TOKEN=verify_token
WHATSAPP_WEBHOOK_SECRET=

# --- Auth / JWT ---
JWT_SECRET=dev-secret-key
JWT_EXPIRY_DURATION=24h
JWT_REFRESH_DURATION=168h
API_KEY_HEADER=X-API-Key

# --- Rate Limiting ---
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=50
RATE_LIMIT_KEY_PREFIX=ratelimit:
RATE_LIMIT_WINDOW=1s
